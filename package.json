    "mongodb": "^6.12.0",
    "next": "15.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
